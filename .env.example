DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
